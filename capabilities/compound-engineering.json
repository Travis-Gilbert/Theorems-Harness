{
  "id": "compound-engineering",
  "title": "Compound Engineering",
  "delivery": "background",
  "priority": 40,
  "must_be_visible_to_model": false,
  "backing": {
    "theorem_verbs": ["skill_apply", "record_use_receipt", "encode"],
    "runtime_modules": ["compound_engineering", "skill_pack"]
  },
  "triggers": {
    "hook_events": ["Stop", "PostToolUse"],
