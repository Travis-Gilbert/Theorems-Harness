{
  "description": "Theorems Harness product hooks for Claude Code.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/session-run-open.mjs\"",
            "timeout": 25,
            "statusMessage": "Opening Theorems Harness session run"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/session-run-close.mjs\"",
            "timeout": 25,
            "statusMessage": "Closing Theorems Harness session run"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/prepare-context.mjs\"",
            "timeout": 10,
            "statusMessage": "Preparing Theorems Harness capability packet"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/pretool-context.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking Theorems Harness capability triggers"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/prepare-context.mjs\"",
            "timeout": 10,
            "statusMessage": "Recording Theorems Harness outcome signals"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/bin/session-run-tool.mjs\"",
            "timeout": 10,
            "statusMessage": "Recording Theorems Harness session run tool event"
          }
        ]
      }
    ]
  }
}
