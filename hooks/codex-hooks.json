{
  "description": "Theorems Harness product hooks for Codex. These hooks compile local capability context before the model acts.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/src/bin/prepare-context.mjs\"",
            "timeout": 10,
            "statusMessage": "Preparing Theorems Harness capability packet"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|exec_command|functions.exec_command|apply_patch|functions.apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/src/bin/pretool-context.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking Theorems Harness capability triggers"
          }
        ]
      }
    ]
  }
}
